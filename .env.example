OPENAI_API_KEY=your_api_key_here

# Main LLM used for parsing, scoring, guidance, and normal chat.
JOB_AGENT_LLM_MODEL=gpt-4o-mini

# Model used only when the chat panel's web-search option is enabled.
# Current OpenAI model docs list GPT-5.4 mini as a lower-latency/cost frontier model with web search support.
JOB_AGENT_WEB_SEARCH_MODEL=gpt-5.4-mini
